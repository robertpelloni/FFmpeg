# FFmpeg .gitignore
#
# List of files/directories that should be ignored by git.
# This is a combination of the upstream FFmpeg ignore list
# and Topaz Video AI specific paths.

# Default gitignore from upstream
/ffmpeg
/ffplay
/ffprobe
/ffserver
/libavcodec/vulkan/*.c
/libavfilter/vulkan/*.c
/.*/
!/.forgejo/

# Common patterns
*.[ao]
*.d
*.gcno
*.gcda
*.gov
*.lib
*.exp
*.dll
*.pdb
*.exe
*.so
*.so.*
*.dylib
*.dylib.*
*.app
*.dmg
*.pkg
*.rpm
*.deb
*.manifest
*.res
*.rc
*.obj
*.bc
*.ll
*.plist
*.nib
*.strings
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
*.xcworkspace
*.xcuserdata
*.xccheckout
*.xccodecaps
*.diagnostics
*.log
*.log.*
*.txt
*.txt.*
*.bak
*.bak.*
*.tmp
*.tmp.*
*.swp
*.swo
*~
.#*
#*#

# Topaz specific
.DS_Store
/output/
.vscode/settings.json
/conan
/output-conan
.vscode/launch.json
/.vscode

# Upstream specific paths
/src
/mapfile
/tools/python/__pycache__/
